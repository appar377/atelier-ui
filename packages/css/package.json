{
  "name": "@appar377/atelier-css",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.css",
  "style": "dist/index.css",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./dist/index.css"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist", "src/index.d.ts"],
